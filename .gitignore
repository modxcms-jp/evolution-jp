/.htaccess
/.env
/manager/includes/config.inc.php
/manager/includes/extra.config.php

# 個人操作履歴
.bash_history
**/.bash_history

# システムが動的に生成するサーバ固有のファイルのため同期が不要なファイル・ディレクトリ
.thumbs/
/temp/cache/*
/temp/*
!/temp/.htaccess

# gitは空のディレクトリを管理しないため、空のディレクトリを同期したい場合は、
# このファイルが存在するディレクトリに.gitkeepという名前の空ファイルを作成してください
!.gitkeep
